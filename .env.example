# ── Luxvance Platform — environment ─────────────────────────────────────────
# Copy to .env.local for local dev, or set these in the Vercel project settings.
# Without the Supabase vars the portal falls back to mock data; without the
# PORTAL_* vars the password gate is OFF (open). Set all four in production.

# Supabase — project sgaeggmkmipcoikzqwpy
# Public (safe to expose): the project URL, inlined into the client bundle.
NEXT_PUBLIC_SUPABASE_URL=https://sgaeggmkmipcoikzqwpy.supabase.co

# SECRET — service-role key. Bypasses RLS, so it is SERVER-ONLY. Never prefix
# with NEXT_PUBLIC_ and never expose it to the browser. Get it from
# credentials/master.env (SUPABASE_SERVICE_KEY) or the Supabase dashboard.
SUPABASE_SERVICE_KEY=

# ── Portal password gate (proxy.ts) ─────────────────────────────────────────
# PORTAL_PASSWORD: the access key clients type at /gate (share this with Paul).
# PORTAL_ACCESS_TOKEN: server-only secret stored in the auth cookie — a long
# random string, NOT the password. Generate with:
#   python3 -c "import secrets; print('tok_'+secrets.token_urlsafe(36))"
PORTAL_PASSWORD=
PORTAL_ACCESS_TOKEN=
